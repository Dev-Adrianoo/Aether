# 📋 TEMPLATE DE CONFIGURAÇÃO - Copie para .env
# Este arquivo pode ser commitado (sem chaves reais)

LUMINA_USER_NAME=

# Wake Word e Áudio
LUMINA_WAKE_WORD=Lumina
LUMINA_AUDIO_SAMPLE_RATE=16000
LUMINA_AUDIO_CHANNELS=1
LUMINA_PHRASE_TIME_LIMIT=5
LUMINA_ENERGY_THRESHOLD=4000

# DeepSeek API via OpenClaude CLI
# Obtenha sua API key em: https://platform.deepseek.com/api_keys
OPENCLAUDE_API_KEY=sua_chave_deepseek_aqui
OPENCLAUDE_BASE_URL=https://api.deepseek.com/v1
OPENCLAUDE_MODEL=deepseek-chat

# Obsidian Vault
OBSIDIAN_VAULT_PATH=C:/Users/Adria/Documents/Obsidian Vault
OBSIDIAN_LOG_FOLDER=Iris_Logs

# TTS Config
TTS_ENGINE=edge-tts  # pyttsx3 ou edge-tts (recomendado: edge-tts)
TTS_VOICE=pt-br
TTS_RATE=150

# Screenshot Config
SCREENSHOT_QUALITY=85
SCREENSHOT_FORMAT=png
SCREENSHOT_SAVE_PATH=./data/screenshots
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Logging
LOG_LEVEL=INFO
LOG_FILE=LUMINA.log
LOG_TO_CONSOLE=true

# 📝 INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Adicione suas chaves API reais no .env
# 3. NUNCA commit arquivos .env com chaves reais
# 4. .env está no .gitignore