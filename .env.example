# TEMPLATE DE CONFIGURACAO - copie para .env
# Este arquivo pode ser commitado. Nao coloque chaves reais aqui.

LUMINA_USER_NAME=Adriano
LUMINA_WAKE_WORD=lumina

# Audio / STT
AUDIO_DEVICE_INDEX=
AUDIO_SAMPLE_RATE=16000
LUMINA_AUDIO_CHANNELS=1
LUMINA_PHRASE_TIME_LIMIT=15
LUMINA_ENERGY_THRESHOLD=4000
GROQ_API_KEY=

# DeepSeek API via cliente OpenAI-compatible
OPENCLAUDE_API_KEY=
OPENCLAUDE_BASE_URL=https://api.deepseek.com/v1
OPENCLAUDE_MODEL=deepseek-chat

# OpenClaude CLI
# Se vazio, config.py tenta usar %APPDATA%/npm/node_modules/@gitlawb/openclaude/dist/cli.mjs
OPENCLAUDE_BIN=
OPENCLAUDE_SENTINEL_TIMEOUT=300

# Obsidian
OBSIDIAN_VAULT_PATH=
OBSIDIAN_DEV_VAULT=
OBSIDIAN_LOG_FOLDER=Lumina_Logs
# Lista separada por ponto e virgula. Se vazio, config.py tenta LOCALAPPDATA e ProgramFiles.
OBSIDIAN_EXE_CANDIDATES=

# TTS
TTS_ENGINE=edge-tts
TTS_VOICE=pt-br
TTS_RATE=150

# Screenshot / OCR
SCREENSHOT_QUALITY=85
SCREENSHOT_FORMAT=png
SCREENSHOT_SAVE_PATH=./data/screenshots
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Logging
LOG_LEVEL=INFO
LOG_FILE=lumina.log
LOG_TO_CONSOLE=true
